<nav class="breadcrumb" aria-label="{{ 'general.breadcrumb' | t }}">
  <a href="{{ routes.root_url }}">{{ 'general.home' | t }}</a><span class="sep">/</span>
  <a href="/pages/services">{{ 'general.services' | t }}</a><span class="sep">/</span>
  <span class="current">{{ section.settings.title }}</span>
</nav>

<div class="svd-hero">
  <div class="svd-media">
    {%- if section.settings.image != blank -%}
      {{ section.settings.image | image_url: width: 1200 | image_tag: alt: section.settings.title }}
    {%- else -%}
      <svg viewBox="0 0 200 200" aria-hidden="true"><g stroke="#1a1a1a" stroke-width="1.6" fill="none"><ellipse cx="100" cy="100" rx="70" ry="50"/><path d="M60 100h80"/></g></svg>
    {%- endif -%}
  </div>
  <div class="svd-copy">
    {%- if section.settings.eyebrow != blank -%}
      <div class="svd-eyebrow">{{ section.settings.eyebrow }}</div>
    {%- endif -%}
    <h1>{{ section.settings.title }}</h1>
    {%- if section.settings.lede != blank -%}
      <p class="lede">{{ section.settings.lede }}</p>
    {%- endif -%}
    <div class="svd-ctas">
      {%- if section.settings.cta_primary_label != blank -%}
        <a href="{{ section.settings.cta_primary_url }}" class="btn solid">{{ section.settings.cta_primary_label }}</a>
      {%- endif -%}
      {%- if section.settings.cta_secondary_label != blank -%}
        <a href="{{ section.settings.cta_secondary_url }}" class="btn ghost">{{ section.settings.cta_secondary_label }}</a>
      {%- endif -%}
    </div>
    <div class="svd-quickspecs">
      {%- for block in section.blocks -%}
        {%- if block.type == 'quickspec' -%}
          <div class="qs" {{ block.shopify_attributes }}>
            <div class="k">{{ block.settings.key }}</div>
            <div class="v">{{ block.settings.value }}</div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Service detail hero",
  "tag": "section",
  "class": "section-service-detail-hero",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Hero image" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "SERVICE 05 — ISLAMIC CALLIGRAPHY" },
    { "type": "text", "id": "title", "label": "Title", "default": "Steel Calligraphy." },
    { "type": "textarea", "id": "lede", "label": "Description", "default": "Ayat, names and duas cut as a single continuous line from steel — for homes, clocks, mosque interiors and commercial facades." },
    { "type": "text", "id": "cta_primary_label", "label": "Primary CTA", "default": "SHOP CALLIGRAPHY →" },
    { "type": "url", "id": "cta_primary_url", "label": "Primary CTA URL" },
    { "type": "text", "id": "cta_secondary_label", "label": "Secondary CTA", "default": "GET CUSTOM QUOTE" },
    { "type": "url", "id": "cta_secondary_url", "label": "Secondary CTA URL", "default": "/pages/contact" }
  ],
  "blocks": [
    {
      "type": "quickspec",
      "name": "Quick spec",
      "settings": [
        { "type": "text", "id": "key", "label": "Label", "default": "From" },
        { "type": "text", "id": "value", "label": "Value", "default": "PKR 8,500" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Service detail hero",
      "blocks": [
        { "type": "quickspec", "settings": { "key": "From", "value": "PKR 8,500" } },
        { "type": "quickspec", "settings": { "key": "Material", "value": "MS / Golden SS" } },
        { "type": "quickspec", "settings": { "key": "Lead Time", "value": "3–5 Days" } },
        { "type": "quickspec", "settings": { "key": "Proof", "value": "Vector Included" } }
      ]
    }
  ]
}
{% endschema %}
