<div class="svd-hero">
  <div class="svd-media">
    {%- if section.settings.image != blank -%}
      {{ section.settings.image | image_url: width: 1200 | image_tag: alt: section.settings.title }}
    {%- else -%}
      <svg viewBox="0 0 200 200" aria-hidden="true"><circle cx="100" cy="100" r="88" fill="none" stroke="#1a1a1a" stroke-width="2"/><g stroke="#1a1a1a" stroke-width="1.6" fill="none"><path d="M100 45c-30 0-40 25-40 55 0 20 15 30 40 30s40-10 40-30c0-30-10-55-40-55z"/><path d="M60 70c10-15 25-20 40-20M60 130c10 15 25 20 40 20"/></g></svg>
    {%- endif -%}
  </div>
  <div class="svd-copy">
    {%- if section.settings.eyebrow != blank -%}
      <div class="svd-eyebrow">{{ section.settings.eyebrow }}</div>
    {%- endif -%}
    <h1>{{ section.settings.title }}</h1>
    {%- if section.settings.lede != blank -%}
      <p class="lede">{{ section.settings.lede }}</p>
    {%- endif -%}
    <div class="svd-ctas">
      {%- if section.settings.cta_primary_label != blank -%}
        <a href="{{ section.settings.cta_primary_url }}" class="btn solid">{{ section.settings.cta_primary_label }}</a>
      {%- endif -%}
      {%- if section.settings.cta_secondary_label != blank -%}
        <a href="{{ section.settings.cta_secondary_url }}" class="btn ghost">{{ section.settings.cta_secondary_label }}</a>
      {%- endif -%}
    </div>
    <div class="svd-quickspecs">
      {%- for block in section.blocks -%}
        {%- if block.type == 'quickspec' -%}
          <div class="qs" {{ block.shopify_attributes }}>
            <div class="k">{{ block.settings.key }}</div>
            <div class="v">{{ block.settings.value }}</div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Service detail hero",
  "tag": "section",
  "class": "section-service-detail-hero",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Hero image" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "SERVICE 05 / 06" },
    { "type": "text", "id": "title", "label": "Title", "default": "Islamic Calligraphy" },
    { "type": "textarea", "id": "lede", "label": "Description", "default": "Ayat, names and duas cut clean from a single continuous line of steel. Every pattern is vectorized from your reference — a photo of a page, a screenshot, even a rough sketch — then cut fresh per order for walls, clocks, gates and mosque interiors." },
    { "type": "text", "id": "cta_primary_label", "label": "Primary CTA", "default": "SEND YOUR TEXT →" },
    { "type": "url", "id": "cta_primary_url", "label": "Primary CTA URL", "default": "https://wa.me/923215568112" },
    { "type": "text", "id": "cta_secondary_label", "label": "Secondary CTA", "default": "SEE READY DESIGNS" },
    { "type": "url", "id": "cta_secondary_url", "label": "Secondary CTA URL", "default": "#products" }
  ],
  "blocks": [
    {
      "type": "quickspec",
      "name": "Quick spec",
      "settings": [
        { "type": "text", "id": "key", "label": "Label", "default": "From" },
        { "type": "text", "id": "value", "label": "Value", "default": "PKR 8,500" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Service detail hero",
      "blocks": [
        { "type": "quickspec", "settings": { "key": "Material", "value": "MS / Golden SS" } },
        { "type": "quickspec", "settings": { "key": "Lead Time", "value": "3–7 Days" } },
        { "type": "quickspec", "settings": { "key": "Tolerance", "value": "± 0.10mm" } },
        { "type": "quickspec", "settings": { "key": "Starting At", "value": "PKR 8,500" } }
      ]
    }
  ]
}
{% endschema %}
