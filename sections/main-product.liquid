<product-info id="MainProduct-{{ section.id }}" class="pdp" data-section="{{ section.id }}">
  <div class="pdp-gallery">
    <div class="pdp-main" id="ProductMainImage">
      {%- if product.tags contains 'bestseller' -%}
        <span class="product-tag laser">{{ 'products.badge.bestseller' | t }}</span>
      {%- elsif product.tags contains 'made-to-order' -%}
        <span class="product-tag">{{ 'products.badge.made_to_order' | t }}</span>
      {%- endif -%}

      {%- if product.featured_media -%}
        {{ product.featured_media | image_url: width: 1200 | image_tag: id: 'ProductMainImg', alt: product.title, data-product-main-image: true }}
      {%- else -%}
        {% render 'product-fallback-svg', product: product %}
      {%- endif -%}
    </div>

    {%- if product.media.size > 1 -%}
      <div class="pdp-thumbs">
        {%- for media in product.media limit: 4 -%}
          <button
            type="button"
            class="pdp-thumb{% if forloop.first %} active{% endif %}"
            data-media-id="{{ media.id }}"
            data-src="{{ media | image_url: width: 1200 }}"
            aria-label="{{ 'products.product.media' | t }}"
          >
            {{ media | image_url: width: 200 | image_tag: loading: 'lazy', alt: media.alt }}
          </button>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>

  <div class="pdp-info">
    {%- if product.type != blank -%}
      <div class="pdp-eyebrow"><span>●</span> {{ product.type | upcase }}</div>
    {%- endif -%}

    <h1>{{ product.title }}</h1>

    <div class="pdp-code">
      {%- assign sku = product.selected_or_first_available_variant.sku -%}
      {%- if sku != blank -%}SKU {{ sku }}{%- endif -%}
      {%- if product.metafields.custom.cut_file != blank -%} &nbsp;·&nbsp; {{ product.metafields.custom.cut_file }}{%- endif -%}
    </div>

    <div class="pdp-price" id="ProductPrice-{{ section.id }}">
      {% render 'price', product: product, use_variant: true, unit_text: product.metafields.custom.unit_text %}
    </div>

    <div class="pdp-stock" id="ProductStock-{{ section.id }}">
      <span class="dot"></span>
      <span data-stock-text>
        {%- if product.selected_or_first_available_variant.available -%}
          {{ 'products.product.in_stock' | t }}
        {%- else -%}
          {{ 'products.product.sold_out' | t }}
        {%- endif -%}
      </span>
    </div>

    {%- if product.description != blank -%}
      <div class="pdp-desc">{{ product.description }}</div>
    {%- endif -%}

    {%- assign product_form_id = 'product-form-' | append: section.id -%}
    {% form 'product', product, id: product_form_id, class: 'product-form', data-product-id: product.id %}
      <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}" data-variant-input>

      <div class="qty-row">
        <div class="qty-box">
          <button type="button" data-qty-minus aria-label="{{ 'products.product.quantity.decrease' | t }}">−</button>
          <span class="qty-value" data-qty-display aria-live="polite">1</span>
          <input type="hidden" name="quantity" value="1" class="qty-input" min="1" aria-label="{{ 'products.product.quantity.label' | t }}">
          <button type="button" data-qty-plus aria-label="{{ 'products.product.quantity.increase' | t }}">+</button>
        </div>
      </div>

      {%- unless product.has_only_default_variant -%}
        {%- for option in product.options_with_values -%}
          <div class="opt-group opt-group--atc" data-option-name="{{ option.name | escape }}">
            <div class="opt-row opt-row--inline" data-option-index="{{ forloop.index0 }}">
              {%- for value in option.values -%}
                {%- if option.name == 'Finish' or option.name == 'finish' -%}
                  {%- assign swatch_color = '#1a1a1a' -%}
                  {%- if value == 'Raw Steel' -%}{%- assign swatch_color = 'linear-gradient(135deg,#9a9d9f,#6a6d6f)' -%}{%- endif -%}
                  {%- if value == 'Golden PVD' -%}{%- assign swatch_color = 'linear-gradient(135deg,#c9a668,#8a6f3f)' -%}{%- endif -%}
                  <button
                    type="button"
                    class="opt-swatch{% if option.selected_value == value %} active{% endif %}"
                    title="{{ value }}"
                    style="background:{{ swatch_color }};"
                    data-option-value="{{ value | escape }}"
                    data-option-name="{{ option.name | escape }}"
                  ></button>
                {%- else -%}
                  <button
                    type="button"
                    class="opt-variant{% if option.selected_value == value %} active{% endif %}"
                    data-option-value="{{ value | escape }}"
                    data-option-name="{{ option.name | escape }}"
                  >{{ value }}</button>
                {%- endif -%}
              {%- endfor -%}
            </div>
            <select class="visually-hidden" name="options[{{ option.name | escape }}]" data-option-select="{{ forloop.index0 }}">
              {%- for value in option.values -%}
                <option value="{{ value | escape }}"{% if option.selected_value == value %} selected{% endif %}>{{ value }}</option>
              {%- endfor -%}
            </select>
          </div>
        {%- endfor -%}
      {%- endunless -%}

      <div class="pdp-ctas">
        <button type="submit" name="add" class="btn solid full" id="AddToCart-{{ section.id }}"{% unless product.selected_or_first_available_variant.available %} disabled{% endunless %}>
          <span data-add-text>{{ 'products.product.add_to_cart' | t }}</span>
        </button>
      </div>
    {% endform %}

    {%- liquid
      assign spec_size = product.metafields.custom.size.value | default: product.metafields.custom.size
      assign spec_material = product.metafields.custom.material.value | default: product.metafields.custom.material
      assign spec_finish = product.metafields.custom.finish.value | default: product.metafields.custom.finish
      assign spec_thickness = product.metafields.custom.thickness.value | default: product.metafields.custom.thickness
      assign spec_short = product.metafields.custom.short_description.value | default: product.metafields.custom.short_description
      assign has_specs = false
      if spec_size != blank or spec_material != blank or spec_finish != blank or spec_thickness != blank or spec_short != blank
        assign has_specs = true
      endif
    -%}

    {%- if has_specs -%}
      <div class="spec-sheet">
        {%- if spec_size != blank -%}
          <div class="spec-row">
            <span class="k">{{ 'products.product.specs.size' | t }}</span>
            <span class="v">{{ spec_size }}</span>
          </div>
        {%- endif -%}
        {%- if spec_material != blank -%}
          <div class="spec-row">
            <span class="k">{{ 'products.product.specs.material' | t }}</span>
            <span class="v">{{ spec_material }}</span>
          </div>
        {%- endif -%}
        {%- if spec_finish != blank -%}
          <div class="spec-row">
            <span class="k">{{ 'products.product.specs.finish' | t }}</span>
            <span class="v">{{ spec_finish }}</span>
          </div>
        {%- endif -%}
        {%- if spec_thickness != blank -%}
          <div class="spec-row">
            <span class="k">{{ 'products.product.specs.thickness' | t }}</span>
            <span class="v">{{ spec_thickness }}</span>
          </div>
        {%- endif -%}
        {%- if spec_short != blank -%}
          <div class="spec-row spec-row--desc">
            <span class="k">{{ 'products.product.specs.short_description' | t }}</span>
            <span class="v">{{ spec_short }}</span>
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="trust-strip">
      {%- for block in section.blocks -%}
        {%- if block.type == 'trust' -%}
          <span {{ block.shopify_attributes }}><span class="dot">◆</span> {{ block.settings.text }}</span>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>

  <script type="application/json" id="ProductJSON-{{ section.id }}">{{ product | json }}</script>
</product-info>

{% schema %}
{
  "name": "Product",
  "tag": "section",
  "class": "section-main-product",
  "blocks": [
    {
      "type": "trust",
      "name": "Trust item",
      "settings": [
        { "type": "text", "id": "text", "label": "Text", "default": "CUT TO ORDER" }
      ]
    }
  ],
  "settings": [],
  "presets": [
    {
      "name": "Product",
      "blocks": [
        { "type": "trust", "settings": { "text": "CUT TO ORDER" } },
        { "type": "trust", "settings": { "text": "RAWALPINDI PICKUP AVAILABLE" } },
        { "type": "trust", "settings": { "text": "WHATSAPP SUPPORT" } }
      ]
    }
  ]
}
{% endschema %}
