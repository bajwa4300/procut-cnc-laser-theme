<div class="svc-head">
  <h1>{{ section.settings.title }}</h1>
  {%- if section.settings.subtitle != blank -%}
    <p>{{ section.settings.subtitle }}</p>
  {%- endif -%}
</div>

<div class="svc-list">
  {%- for block in section.blocks -%}
    <a href="{{ block.settings.link | default: '#' }}" class="svc-item" {{ block.shopify_attributes }}>
      <span class="svc-num">{{ block.settings.number }}</span>
      <div class="svc-icon">
        {%- if block.settings.icon_image != blank -%}
          {{ block.settings.icon_image | image_url: width: 128 | image_tag: alt: block.settings.title }}
        {%- else -%}
          <svg viewBox="0 0 200 200" aria-hidden="true"><rect x="30" y="30" width="140" height="140" fill="none" stroke="#1a1a1a" stroke-width="2"/></svg>
        {%- endif -%}
      </div>
      <div class="svc-body">
        <h3>{{ block.settings.title }}</h3>
        <p>{{ block.settings.description }}</p>
      </div>
      <div class="svc-mat">
        {%- assign mats = block.settings.materials | split: ',' -%}
        {%- for mat in mats -%}
          <span>{{ mat | strip }}</span>
        {%- endfor -%}
      </div>
      <div class="svc-price">
        {{ block.settings.price }}
        {%- if block.settings.price_unit != blank -%}
          <small>{{ block.settings.price_unit }}</small>
        {%- endif -%}
      </div>
      <span class="svc-arrow">→</span>
    </a>
  {%- endfor -%}
</div>

{%- if section.settings.show_cta -%}
  <section class="section svc-cta">
    <div class="section-head">
      <div>
        <span class="section-tag">{{ section.settings.cta_tag }}</span>
        <h2>{{ section.settings.cta_title }}</h2>
      </div>
      <p>{{ section.settings.cta_description }}</p>
    </div>
    <div class="hero-ctas">
      <a href="https://wa.me/{{ settings.whatsapp_number }}" class="btn solid" target="_blank" rel="noopener">{{ section.settings.cta_whatsapp_label }}</a>
      <a href="/pages/contact" class="btn ghost">{{ section.settings.cta_contact_label }}</a>
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "Services list",
  "tag": "section",
  "class": "section-services-list",
  "settings": [
    { "type": "text", "id": "title", "label": "Title", "default": "What We Cut." },
    { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "06 DISCIPLINES — ONE FIBER LASER — RATTA ROAD, RAWALPINDI" },
    { "type": "checkbox", "id": "show_cta", "label": "Show bottom CTA", "default": true },
    { "type": "text", "id": "cta_tag", "label": "CTA tag", "default": "Not Sure?" },
    { "type": "text", "id": "cta_title", "label": "CTA title", "default": "Not Sure Which?" },
    { "type": "textarea", "id": "cta_description", "label": "CTA description", "default": "Send a photo of what you need cut. We quote most jobs same day on WhatsApp." },
    { "type": "text", "id": "cta_whatsapp_label", "label": "WhatsApp button", "default": "WHATSAPP US →" },
    { "type": "text", "id": "cta_contact_label", "label": "Contact button", "default": "VISIT WORKSHOP" }
  ],
  "blocks": [
    {
      "type": "service",
      "name": "Service",
      "settings": [
        { "type": "text", "id": "number", "label": "Number", "default": "01" },
        { "type": "image_picker", "id": "icon_image", "label": "Icon image" },
        { "type": "text", "id": "title", "label": "Title", "default": "Service" },
        { "type": "textarea", "id": "description", "label": "Description" },
        { "type": "text", "id": "materials", "label": "Materials (comma-separated)", "default": "MS, SS" },
        { "type": "text", "id": "price", "label": "Price text", "default": "From PKR 450" },
        { "type": "text", "id": "price_unit", "label": "Price unit", "default": "per kg" },
        { "type": "url", "id": "link", "label": "Detail page link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Services list",
      "blocks": [
        { "type": "service", "settings": { "number": "01", "title": "CNC Laser Cutting", "description": "Precision sheet cutting for mechanical parts, brackets, gears and custom components — priced by weight or by the sheet.", "materials": "MS, SS, Golden SS, Aluminium", "price": "From PKR 450", "price_unit": "per kg" } },
        { "type": "service", "settings": { "number": "02", "title": "Gates & Doors", "description": "Custom double-leaf and single-leaf security gates with geometric or ornamental patterns.", "materials": "MS Sheet", "price": "From PKR 45,000", "price_unit": "per gate" } },
        { "type": "service", "settings": { "number": "03", "title": "Railing & Stairs", "description": "Ornamental infill panels for staircases, balconies and balustrades.", "materials": "MS, SS", "price": "PKR 3,200", "price_unit": "per ft" } },
        { "type": "service", "settings": { "number": "04", "title": "Front Elevation", "description": "Facade cladding and jaali-style screens with standoff mounting.", "materials": "Aluminium, Golden SS", "price": "PKR 6,800", "price_unit": "per sq.ft" } },
        { "type": "service", "settings": { "number": "05", "title": "Islamic Calligraphy", "description": "Ayat, names and duas cut clean from steel — for walls, clocks and mosque interiors.", "materials": "MS, Golden SS", "price": "From PKR 8,500", "price_unit": "per piece", "link": "/pages/islamic-calligraphy" } },
        { "type": "service", "settings": { "number": "06", "title": "Partition Panels", "description": "Modular jaali dividers that split a room without closing it off.", "materials": "MS, Aluminium", "price": "PKR 14,000", "price_unit": "per panel" } }
      ]
    }
  ]
}
{% endschema %}
