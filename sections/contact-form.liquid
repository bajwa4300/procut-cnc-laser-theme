<nav class="breadcrumb" aria-label="{{ 'general.breadcrumb' | t }}">
  <a href="{{ routes.root_url }}">{{ 'general.home' | t }}</a><span class="sep">/</span>
  <span class="current">{{ 'general.contact' | t }}</span>
</nav>

<div class="ct-head">
  <h1>{{ section.settings.title }}</h1>
  {%- if section.settings.subtitle != blank -%}
    <p>{{ section.settings.subtitle }}</p>
  {%- endif -%}
</div>

<div class="ct-body">
  <div class="ct-form-wrap">
    <h2>{{ section.settings.form_title }}</h2>
    {%- if section.settings.form_subtitle != blank -%}
      <p class="sub">{{ section.settings.form_subtitle }}</p>
    {%- endif -%}

    {%- form 'contact', id: 'ContactForm' -%}
      {%- if form.posted_successfully? -%}
        <div class="form-success" id="formOk">
          ● {{ 'templates.contact.form.post_success' | t }}
        </div>
      {%- endif -%}

      {%- if form.errors -%}
        <div class="form-errors">
          {{ form.errors | default_errors }}
        </div>
      {%- endif -%}

      <div class="field-row">
        <div class="field">
          <label for="ContactForm-name">{{ 'templates.contact.form.name' | t }}</label>
          <input type="text" id="ContactForm-name" name="contact[name]" placeholder="{{ 'templates.contact.form.name_placeholder' | t }}" required>
        </div>
        <div class="field">
          <label for="ContactForm-phone">{{ 'templates.contact.form.phone' | t }}</label>
          <input type="tel" id="ContactForm-phone" name="contact[phone]" placeholder="{{ 'templates.contact.form.phone_placeholder' | t }}" required>
        </div>
      </div>

      <div class="field">
        <label for="ContactForm-email">{{ 'templates.contact.form.email' | t }}</label>
        <input type="email" id="ContactForm-email" name="contact[email]" placeholder="{{ 'templates.contact.form.email_placeholder' | t }}">
      </div>

      <div class="field">
        <label>{{ 'templates.contact.form.service_type' | t }}</label>
        <div class="radio-row" data-service-pills>
          {%- for block in section.blocks -%}
            {%- if block.type == 'service_type' -%}
              <button type="button" class="radio-pill{% if forloop.first %} active{% endif %}" data-value="{{ block.settings.value }}" {{ block.shopify_attributes }}>
                {{ block.settings.label }}
              </button>
            {%- endif -%}
          {%- endfor -%}
        </div>
        <input type="hidden" name="contact[service_type]" id="ContactForm-service" value="{{ section.blocks.first.settings.value }}">
      </div>

      <div class="field-row">
        <div class="field">
          <label for="ContactForm-material">{{ 'templates.contact.form.material' | t }}</label>
          <select id="ContactForm-material" name="contact[material]">
            {%- for block in section.blocks -%}
              {%- if block.type == 'material_option' -%}
                <option value="{{ block.settings.value }}">{{ block.settings.label }}</option>
              {%- endif -%}
            {%- endfor -%}
          </select>
        </div>
        <div class="field">
          <label for="ContactForm-size">{{ 'templates.contact.form.size' | t }}</label>
          <input type="text" id="ContactForm-size" name="contact[size]" placeholder="{{ 'templates.contact.form.size_placeholder' | t }}">
        </div>
      </div>

      <div class="field">
        <label for="ContactForm-body">{{ 'templates.contact.form.details' | t }}</label>
        <textarea id="ContactForm-body" name="contact[body]" placeholder="{{ 'templates.contact.form.details_placeholder' | t }}"></textarea>
      </div>

      <div class="form-foot">
        <button type="submit" class="btn solid">{{ 'templates.contact.form.submit' | t }}</button>
        <span class="note">{{ section.settings.form_note }}</span>
      </div>
    {%- endform -%}
  </div>

  <div class="ct-info">
    <div class="info-block">
      <h5>{{ 'templates.contact.info.direct' | t }}</h5>
      <div class="info-row"><span class="k">WhatsApp</span><span class="v"><a href="https://wa.me/{{ settings.whatsapp_number }}">{{ settings.phone }}</a></span></div>
      <div class="info-row"><span class="k">{{ 'templates.contact.info.call' | t }}</span><span class="v"><a href="tel:{{ settings.phone | replace: '-', '' }}">{{ settings.phone }}</a></span></div>
      <div class="info-row"><span class="k">Email</span><span class="v"><a href="mailto:{{ settings.email }}">{{ settings.email }}</a></span></div>
      {%- if settings.social_facebook != blank -%}
        <div class="info-row"><span class="k">Facebook</span><span class="v"><a href="{{ settings.social_facebook }}">ProCut CNC Laser</a></span></div>
      {%- endif -%}
    </div>

    <div class="info-block">
      <h5>{{ 'templates.contact.info.address' | t }}</h5>
      {%- liquid
        assign map_zoom = section.settings.map_zoom | default: 16
        if section.settings.map_embed_src != blank
          assign map_src = section.settings.map_embed_src
        elsif section.settings.map_place_query != blank
          assign map_query = section.settings.map_place_query | url_encode
          assign map_src = 'https://www.google.com/maps/embed?q=' | append: map_query | append: '&z=' | append: map_zoom | append: '&hl=en'
        else
          assign map_lat = section.settings.map_latitude | default: '33.611001'
          assign map_lng = section.settings.map_longitude | default: '73.050037'
          assign map_src = 'https://www.google.com/maps/embed?q=' | append: map_lat | append: ',' | append: map_lng | append: '&z=' | append: map_zoom | append: '&hl=en'
        endif
        assign directions_url = section.settings.map_directions_url | default: 'https://maps.app.goo.gl/iypC8KXL7ydVvyB49'
      -%}
      <div class="map-box">
        <iframe
          class="map-embed"
          title="{{ 'templates.contact.info.map_title' | t }}"
          src="{{ map_src }}"
          referrerpolicy="no-referrer-when-downgrade"
          allowfullscreen
          allow="fullscreen"
          data-map-src="{{ map_src }}"
        ></iframe>
      </div>
      <div class="map-cta">
        <span>{{ settings.workshop_address | newline_to_br | strip_html }}</span>
        <a href="{{ directions_url }}" target="_blank" rel="noopener noreferrer">
          {{ 'templates.contact.info.directions' | t }} →
        </a>
      </div>
    </div>

    <div class="info-block">
      <h5>{{ 'templates.contact.info.hours' | t }}</h5>
      <div class="hours-grid">
        {%- for block in section.blocks -%}
          {%- if block.type == 'hours' -%}
            <div class="day" {{ block.shopify_attributes }}>{{ block.settings.day }}</div>
            <div class="time">{{ block.settings.time }}</div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
</div>

<div class="ct-cta-strip">
  {%- for block in section.blocks -%}
    {%- if block.type == 'cta_tile' -%}
      <a href="{{ block.settings.url }}" class="cta-tile" {{ block.shopify_attributes }}>
        <span class="tag">{{ block.settings.tag }}</span>
        <h4>{{ block.settings.title }}</h4>
        <p>{{ block.settings.description }}</p>
      </a>
    {%- endif -%}
  {%- endfor -%}
</div>

{% schema %}
{
  "name": "Contact form",
  "tag": "section",
  "class": "section-contact-form",
  "settings": [
    { "type": "text", "id": "title", "label": "Page title", "default": "Talk To Us." },
    { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "M. HASSAN — RATTA ROAD, RAWALPINDI — MOST JOBS QUOTED SAME DAY" },
    { "type": "text", "id": "form_title", "label": "Form title", "default": "Request a Quote" },
    { "type": "textarea", "id": "form_subtitle", "label": "Form subtitle", "default": "Tell us what you need cut. Attach a photo or sketch if you have one — WhatsApp works too if that's easier." },
    { "type": "text", "id": "form_note", "label": "Form note", "default": "We reply by WhatsApp or call within one working day." },
    { "type": "textarea", "id": "map_embed_src", "label": "Map embed URL (optional override)", "info": "Paste the full src URL from Google Maps Share → Embed a map. Leave blank to auto-generate from place query below." },
    { "type": "text", "id": "map_place_query", "label": "Map place query", "default": "Shop W/572, Ratta Road, Rawalpindi, Pakistan" },
    { "type": "text", "id": "map_latitude", "label": "Map latitude (fallback)", "default": "33.611001" },
    { "type": "text", "id": "map_longitude", "label": "Map longitude (fallback)", "default": "73.050037" },
    { "type": "range", "id": "map_zoom", "min": 10, "max": 20, "step": 1, "label": "Map zoom level", "default": 16 },
    { "type": "url", "id": "map_directions_url", "label": "Directions URL" }
  ],
  "blocks": [
    { "type": "service_type", "name": "Service type pill", "settings": [
      { "type": "text", "id": "label", "label": "Label", "default": "Calligraphy" },
      { "type": "text", "id": "value", "label": "Value", "default": "Calligraphy" }
    ]},
    { "type": "material_option", "name": "Material option", "settings": [
      { "type": "text", "id": "label", "label": "Label", "default": "Mild Steel" },
      { "type": "text", "id": "value", "label": "Value", "default": "Mild Steel" }
    ]},
    { "type": "hours", "name": "Hours row", "settings": [
      { "type": "text", "id": "day", "label": "Day", "default": "Monday – Saturday" },
      { "type": "text", "id": "time", "label": "Time", "default": "9:00 AM – 7:00 PM" }
    ]},
    { "type": "cta_tile", "name": "CTA tile", "settings": [
      { "type": "text", "id": "tag", "label": "Tag", "default": "Fastest" },
      { "type": "text", "id": "title", "label": "Title", "default": "WhatsApp Us" },
      { "type": "textarea", "id": "description", "label": "Description" },
      { "type": "url", "id": "url", "label": "URL" }
    ]}
  ],
  "presets": [{ "name": "Contact form" }]
}
{% endschema %}
