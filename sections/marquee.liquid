<div class="marquee" id="shopify-section-{{ section.id }}">
  <div class="marquee-track" data-marquee-track>
    {%- for i in (1..2) -%}
      {%- for block in section.blocks -%}
        <span{% if block.settings.accent %} class="accent"{% endif %} {{ block.shopify_attributes }}>{{ block.settings.text }}</span>
        {%- unless forloop.last -%}<span class="accent">◆</span>{%- endunless -%}
      {%- endfor -%}
      {%- if section.blocks.size > 0 -%}<span class="accent">◆</span>{%- endif -%}
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Marquee",
  "tag": "section",
  "class": "section-marquee",
  "blocks": [
    {
      "type": "item",
      "name": "Marquee item",
      "settings": [
        { "type": "text", "id": "text", "label": "Text", "default": "MILD STEEL" },
        { "type": "checkbox", "id": "accent", "label": "Accent style", "default": false }
      ]
    }
  ],
  "presets": [
    {
      "name": "Marquee",
      "blocks": [
        { "type": "item", "settings": { "text": "MILD STEEL" } },
        { "type": "item", "settings": { "text": "STAINLESS STEEL" } },
        { "type": "item", "settings": { "text": "GOLDEN SS" } },
        { "type": "item", "settings": { "text": "ALUMINIUM" } },
        { "type": "item", "settings": { "text": "GATES & DOORS" } },
        { "type": "item", "settings": { "text": "RAILINGS" } },
        { "type": "item", "settings": { "text": "ISLAMIC CALLIGRAPHY" } },
        { "type": "item", "settings": { "text": "PARTITION PANELS" } }
      ]
    }
  ]
}
{% endschema %}
