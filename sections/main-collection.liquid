<nav class="breadcrumb" aria-label="{{ 'general.breadcrumb' | t }}">
  <a href="{{ routes.root_url }}">{{ 'general.home' | t }}</a><span class="sep">/</span>
  <span class="current">{{ section.settings.title | default: collection.title }}</span>
</nav>

<div class="shop-head">
  <h1>{{ section.settings.title | default: collection.title }}</h1>
  <p class="count">
    {{ 'collections.product_count' | t: count: collection.products_count }}
    {%- if section.settings.subtitle != blank -%} — {{ section.settings.subtitle }}{%- endif -%}
  </p>
</div>

<div class="shop-body">
  <aside class="filters">
    <form id="CollectionFiltersForm">
      {%- for filter in collection.filters -%}
        <div class="filter-group">
          <h5>{{ filter.label }}</h5>
          {%- case filter.type -%}
            {%- when 'list' -%}
              {%- for value in filter.values -%}
                <label class="filter-opt">
                  <span>
                    <input
                      type="checkbox"
                      name="{{ value.param_name }}"
                      value="{{ value.value }}"
                      {% if value.active %}checked{% endif %}
                      {% if value.count == 0 and value.active == false %}disabled{% endif %}
                    >
                    {{ value.label }}
                  </span>
                  <span class="n">{{ value.count }}</span>
                </label>
              {%- endfor -%}
            {%- when 'price_range' -%}
              <div class="filter-price">
                <input type="number" name="{{ filter.min_value.param_name }}" value="{{ filter.min_value.value | money_without_currency }}" placeholder="Min">
                <input type="number" name="{{ filter.max_value.param_name }}" value="{{ filter.max_value.value | money_without_currency }}" placeholder="Max">
              </div>
          {%- endcase -%}
        </div>
      {%- endfor -%}
      {%- if section.settings.show_filter_cta -%}
        <a href="/pages/contact" class="btn solid full">{{ section.settings.filter_cta_label }}</a>
      {%- endif -%}
    </form>
  </aside>

  <div class="shop-grid-wrap">
    <div class="toolbar">
      <span>{{ collection.products_count }} {{ 'collections.items' | t }}</span>
      <form>
        <select name="sort_by" id="SortBy" onchange="this.form.submit()">
          {%- for option in collection.sort_options -%}
            <option value="{{ option.value }}"{% if option.value == collection.sort_by %} selected{% endif %}>{{ option.name }}</option>
          {%- endfor -%}
        </select>
      </form>
    </div>

    <div class="product-grid" id="ProductGrid">
      {%- paginate collection.products by section.settings.products_per_page -%}
        {%- for product in collection.products -%}
          {% render 'product-card', product: product, show_add_button: true, show_description: true %}
        {%- else -%}
          <p class="collection-empty">{{ 'collections.empty' | t }}</p>
        {%- endfor -%}
        {%- if paginate.pages > 1 -%}
          <div class="pagination">{{ paginate | default_pagination }}</div>
        {%- endif -%}
      {%- endpaginate -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Collection",
  "tag": "section",
  "class": "section-main-collection",
  "settings": [
    { "type": "text", "id": "title", "label": "Title override", "default": "The Catalog." },
    { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "READY TO ORDER OR RE-QUOTE TO YOUR SIZE" },
    { "type": "range", "id": "products_per_page", "min": 6, "max": 24, "step": 3, "label": "Products per page", "default": 12 },
    { "type": "checkbox", "id": "show_filter_cta", "label": "Show filter CTA button", "default": true },
    { "type": "text", "id": "filter_cta_label", "label": "Filter CTA label", "default": "REQUEST CUSTOM CUT →" }
  ]
}
{% endschema %}
