{%- liquid
  assign card_product = product
  if card_product == blank
    assign card_product = product_ref
  endif
  assign sku = card_product.selected_or_first_available_variant.sku
  assign unit_text = card_product.metafields.custom.unit_text
  assign is_quote = false
  if card_product.tags contains 'made-to-order'
    assign is_quote = true
  endif
  assign is_b2b = false
  if card_product.tags contains 'b2b'
    assign is_b2b = true
  endif
  assign product_tags = card_product.tags | join: ','
  assign current_variant = card_product.selected_or_first_available_variant
-%}

<div
  class="product-card"
  data-product-card
  data-tags="{{ product_tags | downcase }}"
>
  <a href="{{ card_product.url }}" class="product-card-link">
    <div class="product-media">
      {%- if card_product.tags contains 'bestseller' -%}
        <span class="product-tag laser">{{ 'products.badge.bestseller' | t }}</span>
      {%- elsif card_product.tags contains 'made-to-order' -%}
        <span class="product-tag">{{ 'products.badge.made_to_order' | t }}</span>
      {%- elsif card_product.tags contains 'b2b' -%}
        <span class="product-tag">{{ 'products.badge.b2b' | t }}</span>
      {%- endif -%}

      {%- if card_product.featured_image -%}
        {{ card_product.featured_image | image_url: width: 600 | image_tag: loading: 'lazy', alt: card_product.title, class: 'product-card-image product-card-image--primary', data-card-image: true }}
        {%- if card_product.images.size > 1 -%}
          {{ card_product.images[1] | image_url: width: 600 | image_tag: loading: 'lazy', alt: card_product.title, class: 'product-card-image product-card-image--secondary', aria-hidden: 'true' }}
        {%- endif -%}
      {%- else -%}
        {% render 'product-fallback-svg', product: card_product %}
      {%- endif -%}
    </div>
    <div class="product-info">
      <div class="pi-top">
        <h3>{{ card_product.title }}</h3>
        {%- if sku != blank -%}
          <span class="code">SKU {{ sku }}</span>
        {%- endif -%}
      </div>
      {%- if card_product.description != blank and show_description -%}
        <p class="desc">{{ card_product.description | strip_html | truncate: 120 }}</p>
      {%- endif -%}

      {%- unless card_product.has_only_default_variant or is_quote or is_b2b -%}
        {%- for option in card_product.options_with_values -%}
          {%- unless option.name == 'Finish' or option.name == 'finish' -%}
            {%- assign opt_n = forloop.index -%}
            <div class="card-variants opt-row opt-row--inline" data-card-variants>
              {%- for value in option.values -%}
                {%- assign matched = blank -%}
                {%- for v in card_product.variants -%}
                  {%- if opt_n == 1 and v.option1 == value -%}
                    {%- assign matched = v -%}
                  {%- elsif opt_n == 2 and v.option2 == value -%}
                    {%- assign matched = v -%}
                  {%- elsif opt_n == 3 and v.option3 == value -%}
                    {%- assign matched = v -%}
                  {%- endif -%}
                {%- endfor -%}
                {%- if matched != blank -%}
                  <button
                    type="button"
                    class="opt-variant{% if matched.id == current_variant.id %} active{% endif %}"
                    data-card-variant
                    data-variant-id="{{ matched.id }}"
                    data-price="{{ matched.price }}"
                    data-available="{{ matched.available }}"
                    {% if matched.featured_image %}data-image="{{ matched.featured_image | image_url: width: 600 }}"{% endif %}
                    onclick="event.preventDefault();event.stopPropagation();"
                  >{{ value }}</button>
                {%- endif -%}
              {%- endfor -%}
            </div>
          {%- endunless -%}
        {%- endfor -%}
      {%- endunless -%}

      <div class="pi-bottom">
        {% render 'price', product: card_product, show_from: false, use_variant: true, unit_text: unit_text %}
        {%- if show_add_button -%}
          {%- if is_quote or is_b2b -%}
            <a href="/pages/contact" class="add-btn" onclick="event.stopPropagation()">
              {%- if is_b2b -%}
                {{ 'products.product.upload_file' | t }}
              {%- else -%}
                {{ 'products.product.get_quote' | t }}
              {%- endif -%}
            </a>
          {%- else -%}
            <button
              type="button"
              class="add-btn product-card-add"
              data-variant-id="{{ current_variant.id }}"
              data-product-id="{{ card_product.id }}"
              {% unless current_variant.available %}disabled{% endunless %}
              onclick="event.preventDefault();event.stopPropagation()"
            >
              {{ 'products.product.add_short' | t }}
            </button>
          {%- endif -%}
        {%- endif -%}
      </div>
    </div>
  </a>
</div>
