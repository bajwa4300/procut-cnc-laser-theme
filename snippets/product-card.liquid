{%- liquid
  assign card_product = product
  if card_product == blank
    assign card_product = product_ref
  endif
  assign sku = card_product.selected_or_first_available_variant.sku
  assign unit_text = card_product.metafields.custom.unit_text
  assign is_quote = false
  if card_product.tags contains 'made-to-order'
    assign is_quote = true
  endif
  assign is_b2b = false
  if card_product.tags contains 'b2b'
    assign is_b2b = true
  endif
  assign product_tags = card_product.tags | join: ','
-%}

<div
  class="product-card"
  data-product-card
  data-tags="{{ product_tags | downcase }}"
>
  <a href="{{ card_product.url }}" class="product-card-link">
    <div class="product-media">
      {%- if card_product.tags contains 'bestseller' -%}
        <span class="product-tag laser">{{ 'products.badge.bestseller' | t }}</span>
      {%- elsif card_product.tags contains 'made-to-order' -%}
        <span class="product-tag">{{ 'products.badge.made_to_order' | t }}</span>
      {%- elsif card_product.tags contains 'b2b' -%}
        <span class="product-tag">{{ 'products.badge.b2b' | t }}</span>
      {%- endif -%}

      {%- if card_product.featured_image -%}
        {{ card_product.featured_image | image_url: width: 600 | image_tag: loading: 'lazy', alt: card_product.title, class: 'product-card-image' }}
      {%- else -%}
        {% render 'product-fallback-svg', product: card_product %}
      {%- endif -%}
    </div>
    <div class="product-info">
      <div class="pi-top">
        <h3>{{ card_product.title }}</h3>
        {%- if sku != blank -%}
          <span class="code">SKU {{ sku }}</span>
        {%- endif -%}
      </div>
      {%- if card_product.description != blank and show_description -%}
        <p class="desc">{{ card_product.description | strip_html | truncate: 120 }}</p>
      {%- endif -%}
      <div class="pi-bottom">
        {% render 'price', product: card_product, show_from: true, unit_text: unit_text %}
        {%- if show_add_button -%}
          {%- if is_quote or is_b2b -%}
            <a href="/pages/contact" class="add-btn" onclick="event.stopPropagation()">
              {%- if is_b2b -%}
                {{ 'products.product.upload_file' | t }}
              {%- else -%}
                {{ 'products.product.get_quote' | t }}
              {%- endif -%}
            </a>
          {%- else -%}
            <button
              type="button"
              class="add-btn product-card-add"
              data-variant-id="{{ card_product.selected_or_first_available_variant.id }}"
              data-product-id="{{ card_product.id }}"
              {% unless card_product.selected_or_first_available_variant.available %}disabled{% endunless %}
              onclick="event.preventDefault();event.stopPropagation()"
            >
              {{ 'products.product.add_short' | t }}
            </button>
          {%- endif -%}
        {%- endif -%}
      </div>
    </div>
  </a>
</div>
